# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="supabase-anon-key"
# Clé secrète « service_role » (Supabase > Paramètres > API) — nécessaire pour le dashboard / admin
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key"

# Stripe (étapes ultérieures)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Application (local = localhost, production = URL du site ex. https://votre-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Ou utilisez NEXT_PUBLIC_SITE_URL pour la prod (Vercel : définir dans Project Settings > Environment Variables)
NEXT_PUBLIC_SITE_URL="https://votre-app.vercel.app"
